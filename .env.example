# --- LLM provider ---
LLM_PROVIDER=ollama            # ollama | anthropic

# Ollama Cloud (default provider). Get a key at https://ollama.com (account settings).
OLLAMA_API_KEY=
# OLLAMA_HOST=https://ollama.com
# OLLAMA_MODEL=gpt-oss:120b    # optional: skip the interactive picker (src.select_model)

# Anthropic (only needed if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-5

# optional overrides
# RETRIEVAL_MODE=hybrid
# TOP_K=5
# CHUNK_SIZE_WORDS=350

# v3 ablation
# PROMPT_VARIANT=grounded        # naive | grounded

# optional tracing (pip install "langfuse>=2,<3")
# LANGFUSE_ENABLED=true
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=http://localhost:3000
